{
  "expo": {
    "scheme": "healthdoc",
    "name": "HealthApp",
    "slug": "HealthApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/pibble.jpg",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nmlcode.healthdoc"
    },
    "android": {
      "package": "com.nmlcode.healthdoc",
      "permissions" : ["SCHEDULE_EXACT_ALARM"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4dc17457-3737-4f4b-9f07-7e04325df296"
      }
    }
  }
}
