{
  "expo": {
    "scheme": "healthdoc",
    "name": "Health Doc",
    "slug": "HealthApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_variants/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon_variants/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#e0dfe8",
      "dark" : {
        "backgroundColor" : "#252231"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nmlcode.healthdoc"
    },
    "android": {
      "package": "com.nmlcode.healthdoc",
      "permissions" : ["USE_EXACT_ALARM","RECEIVE_BOOT_COMPLETED"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_variants/icon.png",
        "backgroundColor": "#313131"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/icon_variants/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4dc17457-3737-4f4b-9f07-7e04325df296"
      }
    }
  }
}
